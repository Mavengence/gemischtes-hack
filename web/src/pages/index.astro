<!-- Episode card click → open viewer + exploration tracking -->
<script>
  const EXPLORE_KEY = "gh_explored_episodes";
  const exploreTracker = document.getElementById("explore-tracker");
  const exploreCount = document.getElementById("explore-count");
  const exploreBar = document.getElementById("explore-bar");
  const totalEpisodes = parseInt(exploreCount?.parentElement?.querySelector(".text-gray-400")?.textContent ?? "0", 10);

  function getExploredSet(): Set<string> {
    try {
      return new Set(JSON.parse(localStorage.getItem(EXPLORE_KEY) ?? "[]"));
    } catch { return new Set(); }
  }

  function updateExploreUI() {
    const explored = getExploredSet();
    if (explored.size > 0 && exploreTracker && exploreCount && exploreBar) {
      exploreTracker.classList.remove("hidden");
      exploreCount.textContent = String(explored.size);
      const pct = totalEpisodes > 0 ? (explored.size / totalEpisodes) * 100 : 0;
      exploreBar.style.width = `${Math.min(pct, 100)}%`;
    }
  }

  const MILESTONES: Record<number, string> = {
    5: "5 Folgen erkundet — das ist offiziell eine Serie",
    15: "15 Folgen! Du kennst den Podcast besser als die meisten Gäste",
    30: "30 Folgen — du bist ein echter Gemischtes Hack Experte",
    50: "50 Folgen — du bist jetzt Honorary Host",
  };
  const SHOWN_KEY = "gh_milestones_shown";

  function getShownMilestones(): Set<number> {
    try { return new Set(JSON.parse(localStorage.getItem(SHOWN_KEY) ?? "[]")); } catch { return new Set(); }
  }

  function showToast(message: string) {
    const toast = document.createElement("div");
    toast.style.cssText = "position:fixed;bottom:5rem;left:50%;transform:translateX(-50%) translateY(20px);z-index:9998;background:#161616;border:1px solid rgba(245,192,0,0.2);border-radius:2px;padding:0.75rem 1.5rem;font-size:12px;color:#F5C000;opacity:0;transition:all 400ms ease;pointer-events:none;max-width:90%;text-align:center;white-space:nowrap;";
    toast.textContent = message;
    document.body.appendChild(toast);
    requestAnimationFrame(() => {
      toast.style.opacity = "1";
      toast.style.transform = "translateX(-50%) translateY(0)";
    });
    setTimeout(() => {
      toast.style.opacity = "0";
      toast.style.transform = "translateX(-50%) translateY(20px)";
      setTimeout(() => toast.remove(), 400);
    }, 4000);
  }

  function checkMilestone(count: number) {
    const shown = getShownMilestones();
    for (const [threshold, msg] of Object.entries(MILESTONES)) {
      const n = Number(threshold);
      if (count >= n && !shown.has(n)) {
        shown.add(n);
        try { localStorage.setItem(SHOWN_KEY, JSON.stringify([...shown])); } catch {}
        showToast(msg);
        try { (window as unknown as Record<string, Record<string, () => void>>).__sounds?.ding?.(); } catch {}
        break;
      }
    }
  }

  function trackEpisode(gltId: string) {
    const explored = getExploredSet();
    const isNew = !explored.has(gltId);
    explored.add(gltId);
    try { localStorage.setItem(EXPLORE_KEY, JSON.stringify([...explored])); } catch {}
    updateExploreUI();
    if (isNew) checkMilestone(explored.size);
  }

  updateExploreUI();

  document.addEventListener("click", (e) => {
    const card = (e.target as HTMLElement).closest<HTMLElement>(".episode-card");
    if (!card) return;
    // Don't trigger on topic tag clicks
    if ((e.target as HTMLElement).closest(".topic-tag")) return;
    const gltId = card.dataset.gltId;
    if (!gltId) return;
    try { navigator?.vibrate?.(20); } catch {}
    try { (window as unknown as Record<string, Record<string, () => void>>).__sounds?.click?.(); } catch {}
    trackEpisode(gltId);
    const viewer = (window as unknown as Record<string, { open: (id: string) => void }>).__episodeViewer;
    if (viewer) viewer.open(gltId);
  });
</script>

<!-- Haptic + sound utilities -->
<script>
  function haptic(ms = 30) {
    try { navigator?.vibrate?.(ms); } catch {}
  }
  function sfx(name: string) {
    try {
      const s = (window as unknown as Record<string, Record<string, () => void>>).__sounds;
      if (s?.[name]) s[name]();
    } catch {}
  }
  (window as unknown as Record<string, unknown>).__haptic = haptic;
  (window as unknown as Record<string, unknown>).__sfx = sfx;
</script>

<!-- Episode grid expand/collapse + random episode -->
<script>
  const expandBtn = document.getElementById("episode-expand-btn");
  const moreGrid = document.getElementById("episode-grid-more");
  if (expandBtn && moreGrid) {
    expandBtn.addEventListener("click", () => {
      const isHidden = moreGrid.classList.contains("hidden");
      if (isHidden) {
        moreGrid.classList.remove("hidden");
        expandBtn.textContent = "Weniger anzeigen";
        // Staggered cascade reveal
        if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          const cards = moreGrid.querySelectorAll<HTMLElement>(".card");
          cards.forEach((card, i) => {
            card.classList.add("card-stagger");
            card.style.animationDelay = `${i * 40}ms`;
          });
        }
      } else {
        moreGrid.classList.add("hidden");
        expandBtn.textContent = `Alle Folgen anzeigen`;
        // Clean up stagger classes
        moreGrid.querySelectorAll<HTMLElement>(".card-stagger").forEach((card) => {
          card.classList.remove("card-stagger");
          card.style.animationDelay = "";
        });
      }
    });
  }

  // Random episode button with slot-machine flicker
  const randomEpBtn = document.getElementById("random-episode-btn");
  if (randomEpBtn) {
    let flickering = false;
    randomEpBtn.addEventListener("click", () => {
      if (flickering) return;
      try { navigator?.vibrate?.(30); } catch {}
      try { (window as unknown as Record<string, Record<string, () => void>>).__sounds?.tink?.(); } catch {}
      const allCards = document.querySelectorAll<HTMLElement>(".episode-card[data-glt-id]");
      if (allCards.length === 0) return;
      flickering = true;

      const targetCard = allCards[Math.floor(Math.random() * allCards.length)];
      const targetGltId = targetCard.dataset.gltId;
      if (!targetGltId) { flickering = false; return; }

      // Slot-machine flicker: cycle through random numbers
      const btnText = randomEpBtn.querySelector("svg")?.nextSibling;
      const originalText = "Zufällige Folge";
      const totalFlicks = 12;
      let step = 0;

      const flick = () => {
        const randomIdx = Math.floor(Math.random() * allCards.length);
        const card = allCards[randomIdx];
        const epNum = card.querySelector(".font-mono")?.textContent ?? `#${randomIdx + 1}`;
        if (btnText) btnText.textContent = ` Folge ${epNum.replace("#", "")}...`;
        step++;
        if (step < totalFlicks) {
          const delay = 50 + Math.pow(step / totalFlicks, 2) * 200;
          setTimeout(flick, delay);
        } else {
          if (btnText) btnText.textContent = ` ${originalText}`;
          flickering = false;
          const viewer = (window as unknown as Record<string, { open: (id: string) => void }>).__episodeViewer;
          if (viewer) viewer.open(targetGltId);
        }
      };
      setTimeout(flick, 50);
    });
  }
</script>
