    font-size: 2rem;
    color: #F5C000;
    letter-spacing: -0.02em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 768px) {
    .featured-episode {
      padding: 1.25rem 1.5rem;
    }
  }

  /* Hero staggered entrance */
  .hero-enter {
    opacity: 0;
    transform: translateY(20px);
    animation: hero-fade-up 800ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero-enter-1 { animation-delay: 200ms; }
  .hero-enter-2 { animation-delay: 500ms; }
  .hero-enter-3 { animation-delay: 700ms; }
  .hero-enter-4 { animation-delay: 900ms; }
  .hero-enter-5 { animation-delay: 1200ms; }

  @keyframes hero-fade-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Hero search glow pulse — 3 pulses then stop */
  .hero-search-glow {
    animation: search-glow-pulse 2s ease-in-out 3;
    animation-delay: 1.5s;
  }

  @keyframes search-glow-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(245, 192, 0, 0); }
    50% { box-shadow: 0 0 12px 2px rgba(245, 192, 0, 0.12); }
