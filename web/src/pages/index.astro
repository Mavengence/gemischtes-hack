---
import BaseLayout from "@/layouts/BaseLayout.astro";
import TopicTimeline from "@/components/react/TopicTimeline";
import ZitatRoulette from "@/components/react/ZitatRoulette";
import SpeakerDuel from "@/components/react/SpeakerDuel";
import EpisodeEvolution from "@/components/react/EpisodeEvolution";
import FehlkaufCards from "@/components/react/FehlkaufCards";
import RapZitate from "@/components/react/RapZitate";
import ChatBot from "@/components/react/ChatBot";
import EpisodeViewer from "@/components/react/EpisodeViewer";
import { supabase } from "@/lib/supabase";

// Fetch data at build time
const { data: episodes } = await supabase
  .from("episodes")
  .select("id, glt_id, episode_number, title, pub_date, duration_seconds, summary, topics_json")
  .order("pub_date", { ascending: false })
  .limit(60);

const { count: episodeCount } = await supabase
  .from("episodes")
  .select("id", { count: "exact", head: true });

const { data: allEps } = await supabase
  .from("episodes")
  .select("duration_seconds");
const totalMinutes = (allEps ?? []).reduce((sum, ep) => sum + (ep.duration_seconds || 0), 0) / 60;
const totalHours = Math.round(totalMinutes / 60);

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

  if (diffDays === 0) return "Heute";
  if (diffDays === 1) return "Gestern";
  if (diffDays < 7) return `vor ${diffDays} Tagen`;
  if (diffDays < 14) return "vor 1 Woche";
  if (diffDays < 60) return `vor ${Math.floor(diffDays / 7)} Wochen`;

  return date.toLocaleDateString("de-DE", {
    day: "2-digit",
    month: "2-digit",
    year: "2-digit",
  });
}

function formatDuration(seconds: number): string {
  return `${Math.floor(seconds / 60)} min`;
}
---

<BaseLayout title="Startseite">

  <!-- ========== HERO ========== -->
  <section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Background image with parallax -->
    <div class="absolute inset-0 overflow-hidden">
      <img
        id="hero-bg"
        src="/background.jpg"
        alt=""
        class="w-full h-[120%] object-cover object-center will-change-transform"
        loading="eager"
      />
      <div class="hero-overlay absolute inset-0"></div>
    </div>

    <!-- Hero content -->
    <div class="relative z-10 text-center px-6 pt-12">
      <!-- Marquee sign with chase lights -->
      <div class="inline-block relative mb-10 hero-enter hero-enter-1" aria-hidden="true">
        <div class="marquee-lights" id="marquee-lights"></div>
        <div class="marquee-sign">
          <h1 class="font-display text-5xl md:text-7xl lg:text-8xl font-extrabold text-white whitespace-nowrap" style="letter-spacing: -0.02em; line-height: 1.05;">
            GEMISCHTES <span class="text-accent">HACK</span>
          </h1>
        </div>
      </div>

      <p class="text-gray-300 text-sm tracking-[0.25em] uppercase font-display mb-2 hero-enter hero-enter-2">
        Felix Lobrecht & Tommi Schmitt
      </p>

      <!-- Stats as prose sentence -->
      <p class="hero-prose mt-6 mb-8 hero-enter hero-enter-3">
        Über <strong><span class="counter" data-target={episodeCount ?? 0}>0</span> Folgen</strong> und <strong><span class="counter" data-target={totalHours}>0</span>+ Stunden</strong> — jedes Wort transkribiert und durchsuchbar.
      </p>

      <!-- Hero search input — the Perplexity pattern -->
      <div class="hero-search-wrap hero-enter hero-enter-4">
        <form id="hero-search-form" class="hero-search hero-search-glow" autocomplete="off">
          <svg class="hero-search-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          <div class="hero-search-input-wrap">
            <input
              id="hero-search-input"
              type="text"
              class="hero-search-input"
              placeholder=" "
              aria-label="Frag den Podcast"
            />
            <span id="hero-placeholder" class="hero-search-placeholder">Was willst du über Gemischtes Hack wissen?</span>
          </div>
          <button type="submit" class="hero-search-btn" aria-label="Frage stellen">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </button>
        </form>
        <div class="hero-search-hints" id="hero-search-hints">
          <span class="text-gray-600 text-[11px]">z.B.</span>
          <button class="hero-hint-chip" data-question="Worüber reden Felix und Tommi am meisten?">Beliebteste Themen</button>
          <button class="hero-hint-chip" data-question="Was war der lustigste Moment im Podcast?">Lustigster Moment</button>
          <button class="hero-hint-chip" data-question="Erzähl mir über die Running Gags">Running Gags</button>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="mt-10 hero-enter hero-enter-5">
        <a href="#chat" aria-label="Zum Chat scrollen" class="scroll-arrow text-gray-600 hover:text-accent transition-colors inline-block">
          <svg class="w-8 h-8 md:w-6 md:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ========== CHATBOT (first section — hero feature) ========== -->
  <section id="chat" class="py-20 px-6 chat-section reveal">
    <div class="max-w-5xl mx-auto">
      <div class="section-header">
        <div class="section-badge">RAG</div>
        <h2 class="font-display text-5xl md:text-6xl font-extrabold uppercase text-white mb-3" style="letter-spacing: -0.02em;">
          Frag den <span class="text-accent">Podcast</span>
        </h2>
        <p class="text-gray-400 text-sm tracking-[0.15em] uppercase">Stell eine Frage — die KI durchsucht alle Transkripte</p>
      </div>
      <ChatBot client:visible />
    </div>
  </section>

  <!-- ========== RAP ZITATE ========== -->
  <section id="rapzitate" class="py-20 px-6 section-alt reveal">
    <div class="max-w-5xl mx-auto">
      <div class="section-header">
        <div class="section-badge">66 Zitate</div>
        <h2 class="font-display text-5xl md:text-6xl font-extrabold uppercase text-white mb-3" style="letter-spacing: -0.02em;">
          Rap<span class="text-accent">zitate</span>
        </h2>
        <p class="text-gray-400 text-sm tracking-[0.15em] uppercase">Jede Folge beginnt mit einem Rap-Zitat — entdecke sie alle</p>
      </div>
      <RapZitate client:visible />
    </div>
  </section>

  <!-- ========== SPEAKER DUEL ========== -->
  <section id="duel" class="py-20 px-6 reveal">
    <div class="max-w-5xl mx-auto">
      <div class="section-header">
        <div class="section-badge">Daten</div>
        <h2 class="font-display text-5xl md:text-6xl font-extrabold uppercase text-white mb-3" style="letter-spacing: -0.02em;">
          Felix <span class="text-accent">vs</span> Tommi
        </h2>
        <p class="text-gray-400 text-sm tracking-[0.15em] uppercase">Vergleich die Hosts in 5 Kategorien</p>
      </div>
      <SpeakerDuel client:visible />
    </div>
  </section>

  <!-- ========== ZITAT ROULETTE ========== -->
  <section id="roulette" class="py-20 px-6 section-alt reveal">
    <div class="max-w-5xl mx-auto">
      <div class="section-header">
        <div class="section-badge">Zufall</div>
        <h2 class="font-display text-5xl md:text-6xl font-extrabold uppercase text-white mb-3" style="letter-spacing: -0.02em;">
          Zitat-<span class="text-accent">Roulette</span>
        </h2>
        <p class="text-gray-400 text-sm tracking-[0.15em] uppercase">Dreh und lass dich von zufälligen Zitaten überraschen</p>
      </div>
      <ZitatRoulette client:visible />
    </div>
  </section>

  <!-- ========== 5 SCHNELLE FRAGEN ========== -->
  <section id="fehlkauf" class="py-20 px-6 reveal">
    <div class="max-w-5xl mx-auto">
      <div class="section-header">
        <div class="section-badge">10 Gäste</div>
        <h2 class="font-display text-5xl md:text-6xl font-extrabold uppercase text-white mb-3" style="letter-spacing: -0.02em;">
          5 Schnelle <span class="text-accent">Fragen</span>
        </h2>
        <p class="text-gray-400 text-sm tracking-[0.15em] uppercase">Swipe durch die Antworten der Podcast-Gäste</p>
      </div>
      <FehlkaufCards client:visible />
    </div>
  </section>

  <div class="section-divider max-w-5xl mx-auto"></div>

  <!-- ========== EPISODE EVOLUTION ========== -->
  <section id="evolution" class="py-20 px-6 section-alt reveal">
    <div class="max-w-5xl mx-auto">
      <div class="section-header">
        <div class="section-badge">Timeline</div>
        <h2 class="font-display text-5xl md:text-6xl font-extrabold uppercase text-white mb-3" style="letter-spacing: -0.02em;">
          <span class="text-accent">Evolution</span>
        </h2>
        <p class="text-gray-400 text-sm tracking-[0.15em] uppercase">Sieh wie sich der Podcast seit 2017 verändert hat</p>
      </div>
      <EpisodeEvolution client:visible />
    </div>
  </section>

  <div class="section-divider max-w-5xl mx-auto"></div>

  <!-- ========== EPISODES ========== -->
  <section id="episoden" class="py-20 px-6 reveal">
    <div class="max-w-6xl mx-auto">
      <div class="section-header">
        <div class="section-badge">{episodeCount ?? 0} Folgen</div>
        <h2 class="font-display text-5xl md:text-6xl font-extrabold uppercase text-white mb-3" style="letter-spacing: -0.02em;">
          Epi<span class="text-accent">soden</span>
        </h2>
        <p class="text-gray-400 text-sm tracking-[0.15em] uppercase">Klick auf eine Folge und lies das Transkript</p>
      </div>

      <!-- Exploration tracker -->
      <div id="explore-tracker" class="text-center mb-6 hidden">
        <span class="text-[11px] text-gray-500 tracking-[0.1em]">
          Du hast <span id="explore-count" class="text-accent font-medium">0</span> von <span class="text-gray-400">{episodeCount ?? 0}</span> Folgen erkundet
        </span>
        <div class="mt-2 max-w-xs mx-auto h-1 overflow-hidden" style="background: #1F1F1F; border-radius: 1px;">
          <div id="explore-bar" class="h-full transition-all duration-700 ease-out" style="width: 0%; background: linear-gradient(90deg, #F5C000, #C49A00);"></div>
        </div>
      </div>

      {episodes && episodes.length > 0 ? (
        <>
          {/* Featured latest episode — full-width strip */}
          {episodes[0] && (
            <div class="featured-episode mb-8 cursor-pointer episode-card" data-glt-id={episodes[0].glt_id} data-topics={JSON.stringify(episodes[0].topics_json ?? [])}>
              <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-8">
                <div class="shrink-0">
                  <span class="featured-episode-number">#{episodes[0].episode_number}</span>
                  <div class="text-[10px] text-gray-600 uppercase tracking-[0.2em] mt-1">Neueste Folge</div>
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="font-display text-xl md:text-2xl font-bold text-gray-100 mb-2 leading-tight">
                    {episodes[0].title}
                  </h3>
                  {episodes[0].summary && (
                    <p class="text-sm text-gray-400 line-clamp-2 leading-relaxed">{episodes[0].summary}</p>
                  )}
                </div>
                <div class="shrink-0 flex flex-row md:flex-col items-center md:items-end gap-3 md:gap-1 text-xs text-gray-500">
                  <span>{formatDate(episodes[0].pub_date)}</span>
                  <span>{formatDuration(episodes[0].duration_seconds)}</span>
                </div>
              </div>
            </div>
          )}

          <!-- Topic filter bar (hidden by default) -->
          <div id="topic-filter-bar" class="hidden mb-6 flex items-center gap-3">
            <span class="text-xs text-gray-500">Thema:</span>
            <span id="topic-filter-label" class="text-xs text-accent font-medium px-3 py-1" style="background: rgba(245,192,0,0.08); border: 1px solid rgba(245,192,0,0.2); border-radius: 1px;"></span>
            <button id="topic-filter-clear" class="text-xs text-gray-500 hover:text-white transition-colors flex items-center gap-1">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
              Filter entfernen
            </button>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3" id="episode-grid">
            {episodes.slice(1, 10).map((ep) => (
              <div class="card cursor-pointer episode-card" data-glt-id={ep.glt_id} data-topics={JSON.stringify(ep.topics_json ?? [])}>
                <div class="flex items-start justify-between gap-3 mb-2">
                  <h3 class="font-medium text-gray-200 line-clamp-2 text-sm leading-snug">
                    {ep.title}
                  </h3>
                  {ep.episode_number && (
                    <span class="text-xs text-gray-500 font-mono shrink-0">#{ep.episode_number}</span>
                  )}
                </div>
                <div class="flex items-center gap-3 text-xs text-gray-500 mb-3">
                  <span>{formatDate(ep.pub_date)}</span>
                  <span class="text-surface-400">|</span>
                  <span>{formatDuration(ep.duration_seconds)}</span>
                </div>
                {ep.summary && (
                  <p class="text-xs text-gray-400 line-clamp-3 leading-relaxed mb-3">{ep.summary}</p>
                )}
                {ep.topics_json && (ep.topics_json as string[]).length > 0 && (
                  <div class="flex flex-wrap gap-1.5">
                    {(ep.topics_json as string[]).slice(0, 3).map((topic: string) => (
                      <button class="topic-tag text-[11px] bg-surface-300/50 text-gray-400 px-2 py-0.5 hover:text-accent hover:bg-accent/10 transition-colors cursor-pointer" style="border-radius: 1px;" data-topic={topic}>
                        {topic}
                      </button>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
          <div class="hidden mt-3" id="episode-grid-more">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
              {episodes.slice(10).map((ep) => (
                <div class="card cursor-pointer episode-card" data-glt-id={ep.glt_id} data-topics={JSON.stringify(ep.topics_json ?? [])}>
                  <div class="flex items-start justify-between gap-3 mb-2">
                    <h3 class="font-medium text-gray-200 line-clamp-2 text-sm leading-snug">
                      {ep.title}
                    </h3>
                    {ep.episode_number && (
                      <span class="text-xs text-gray-500 font-mono shrink-0">#{ep.episode_number}</span>
                    )}
                  </div>
                  <div class="flex items-center gap-3 text-xs text-gray-500 mb-3">
                    <span>{formatDate(ep.pub_date)}</span>
                    <span class="text-surface-400">|</span>
                    <span>{formatDuration(ep.duration_seconds)}</span>
                  </div>
                  {ep.summary && (
                    <p class="text-xs text-gray-400 line-clamp-3 leading-relaxed mb-3">{ep.summary}</p>
                  )}
                  {ep.topics_json && (ep.topics_json as string[]).length > 0 && (
                    <div class="flex flex-wrap gap-1.5">
                      {(ep.topics_json as string[]).slice(0, 3).map((topic: string) => (
                        <button class="topic-tag text-[11px] bg-surface-300/50 text-gray-400 px-2 py-0.5 hover:text-accent hover:bg-accent/10 transition-colors cursor-pointer" style="border-radius: 1px;" data-topic={topic}>
                          {topic}
                        </button>
                      ))}
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
          {episodes.length > 9 && (
            <div class="flex items-center justify-center gap-3 mt-8 flex-wrap">
              <button
                id="episode-expand-btn"
                class="text-xs text-gray-500 hover:text-accent transition-colors tracking-[0.15em] uppercase py-2.5 px-8"
                style="border: 1px solid #2A2A2A; border-radius: 2px;"
              >
                Alle {episodes.length} Folgen anzeigen
              </button>
              <button
                id="random-episode-btn"
                class="text-xs text-gray-500 hover:text-accent transition-colors tracking-[0.15em] uppercase py-2.5 px-6 flex items-center gap-2"
                style="border: 1px solid #2A2A2A; border-radius: 2px;"
              >
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                Zufällige Folge
              </button>
            </div>
          )}
        </>
      ) : (
        <div class="text-center py-16">
          <p class="text-gray-500 text-sm">Noch keine Episoden in der Datenbank.</p>
        </div>
      )}
    </div>
  </section>

  <!-- ========== TOPICS ========== -->
  <section id="themen" class="py-20 px-6 section-alt reveal">
    <div class="max-w-5xl mx-auto">
      <div class="section-header">
        <div class="section-badge">BERTopic</div>
        <h2 class="font-display text-5xl md:text-6xl font-extrabold uppercase text-white mb-3" style="letter-spacing: -0.02em;">
          The<span class="text-accent">men</span>
        </h2>
        <p class="text-gray-400 text-sm tracking-[0.15em] uppercase">Entdecke die häufigsten Themen aller Folgen</p>
      </div>
      <TopicTimeline client:load />
    </div>
  </section>

  <!-- Episode Viewer Modal (global) -->
  <EpisodeViewer client:load />

</BaseLayout>

<style>
  .hero-overlay {
    background:
      radial-gradient(ellipse 60% 50% at 50% 40%, transparent 30%, rgba(10,10,10,0.85) 100%),
      linear-gradient(to bottom, rgba(10,10,10,0.3) 0%, rgba(10,10,10,0.6) 60%, rgba(10,10,10,1) 100%);
  }

  .scroll-arrow {
    animation: float-down 2.5s ease-in-out infinite;
  }

  /* Hero prose stats */
  .hero-prose {
    font-size: 0.95rem;
    color: #999;
    letter-spacing: 0.01em;
    max-width: 28rem;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
  }

  .hero-prose strong {
    color: #F5C000;
    font-weight: 600;
    background: linear-gradient(90deg, #F5C000 0%, #FFE066 50%, #F5C000 100%);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: text-shimmer 2.5s ease-in-out 1;
    animation-delay: 1.2s;
  }

  @keyframes text-shimmer {
    0% { background-position: 200% center; }
    100% { background-position: -200% center; }
  }

  /* Hero search input */
  .hero-search-wrap {
    max-width: 540px;
    margin: 0 auto;
  }

  .hero-search {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: rgba(22,22,22,0.9);
    border: 1px solid #2A2A2A;
    border-radius: 2px;
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }

  .hero-search:focus-within {
    border-color: rgba(245,192,0,0.3);
    box-shadow: 0 0 0 1px rgba(245,192,0,0.08), 0 4px 20px rgba(0,0,0,0.3);
  }

  .hero-search-icon {
    width: 1.25rem;
    height: 1.25rem;
    color: #555;
    flex-shrink: 0;
  }

  .hero-search-input-wrap {
    flex: 1;
    position: relative;
  }

  .hero-search-input {
    width: 100%;
    background: transparent;
    border: none;
    outline: none;
    color: #e5e5e5;
    font-size: 0.875rem;
    letter-spacing: 0.01em;
    position: relative;
    z-index: 1;
  }

  .hero-search-placeholder {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    color: #555;
    font-size: 0.875rem;
    letter-spacing: 0.01em;
    pointer-events: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
    transition: opacity 400ms ease;
  }

  .hero-search-placeholder.fading {
    opacity: 0;
  }

  /* Hide custom placeholder when input has value */
  .hero-search-input:not(:placeholder-shown) ~ .hero-search-placeholder {
    display: none;
  }

  .hero-search-btn {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(245,192,0,0.1);
    border: 1px solid rgba(245,192,0,0.2);
    border-radius: 2px;
    color: #F5C000;
    transition: background 200ms ease, transform 100ms ease;
    cursor: pointer;
  }

  .hero-search-btn:hover {
    background: rgba(245,192,0,0.18);
  }

  .hero-search-btn:active {
    transform: scale(0.95);
  }

  /* Hero hint chips */
  .hero-search-hints {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .hero-hint-chip {
    font-size: 0.6875rem;
    color: #666;
    padding: 0.3rem 0.65rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 1px;
    cursor: pointer;
    transition: color 200ms ease, border-color 200ms ease, background 200ms ease;
  }

  .hero-hint-chip:hover {
    color: #F5C000;
    border-color: rgba(245,192,0,0.2);
    background: rgba(245,192,0,0.04);
  }

  /* Featured latest episode strip — animated gradient border */
  .featured-episode {
    position: relative;
    padding: 1.5rem 2rem;
    background: #111111;
    border-radius: 2px;
    transition: background 200ms ease, transform 200ms ease, box-shadow 200ms ease;
    z-index: 0;
  }

  .featured-episode::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 2px;
    padding: 1px;
    padding-left: 3px;
    background: linear-gradient(180deg, #F5C000, #5B7DC8, #9C40B0, #F5C000);
    background-size: 100% 300%;
    animation: gradient-shift 6s ease-in-out infinite;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    z-index: -1;
  }

  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 0%; }
    50% { background-position: 0% 100%; }
  }

  .featured-episode:hover {
    background: #161616;
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(245, 192, 0, 0.06);
