<!-- Marquee chase lights (debounced resize) -->
<script>
  let resizeTimer: ReturnType<typeof setTimeout>;

  function createMarqueeLights() {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const container = document.getElementById("marquee-lights");
    if (!container) return;

    const sign = container.parentElement;
    if (!sign) return;

    const rect = sign.getBoundingClientRect();
    const spacing = 36;
    const dots: { x: number; y: number }[] = [];

    for (let x = 0; x <= rect.width; x += spacing) dots.push({ x, y: -6 });
    for (let y = 0; y <= rect.height; y += spacing) dots.push({ x: rect.width + 6, y });
    for (let x = rect.width; x >= 0; x -= spacing) dots.push({ x, y: rect.height + 6 });
    for (let y = rect.height; y >= 0; y -= spacing) dots.push({ x: -6, y });

    const totalDots = dots.length;
    container.innerHTML = "";
    dots.forEach((dot, i) => {
      const el = document.createElement("div");
      el.className = "marquee-dot";
      el.style.left = `${dot.x}px`;
      el.style.top = `${dot.y}px`;
      el.style.animationDelay = `${(i / totalDots) * 2400}ms`;
      container.appendChild(el);
    });
  }

  document.fonts.ready.then(createMarqueeLights);
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(createMarqueeLights, 150);
  });
</script>

<!-- Scroll reveal animation -->
<script>
  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("revealed");
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.08, rootMargin: "0px 0px -40px 0px" },
    );
    document.querySelectorAll(".reveal").forEach((el) => revealObserver.observe(el));
  } else {
    document.querySelectorAll(".reveal").forEach((el) => el.classList.add("revealed"));
  }
</script>

<!-- Hero search → dispatch to chatbot -->
<script>
  const heroForm = document.getElementById("hero-search-form");
  const heroInput = document.getElementById("hero-search-input") as HTMLInputElement | null;
  const heroHints = document.getElementById("hero-search-hints");

  function submitHeroQuestion(question: string) {
    if (!question.trim()) return;
    // Scroll to chat section
    const chatEl = document.getElementById("chat");
    if (chatEl) chatEl.scrollIntoView({ behavior: "smooth", block: "start" });
    // Dispatch to ChatBot
    setTimeout(() => {
      window.dispatchEvent(new CustomEvent("hero-ask", { detail: question.trim() }));
    }, 400);
    if (heroInput) heroInput.value = "";
  }

  heroForm?.addEventListener("submit", (e) => {
    e.preventDefault();
    if (heroInput) submitHeroQuestion(heroInput.value);
  });

  heroHints?.querySelectorAll<HTMLButtonElement>(".hero-hint-chip").forEach((chip) => {
    chip.addEventListener("click", (e) => {
      e.preventDefault();
      const q = chip.dataset.question;
      if (q) submitHeroQuestion(q);
    });
  });

  // Typewriter placeholder effect
  const placeholderEl = document.getElementById("hero-placeholder");
  const placeholders = [
    "Was willst du über Gemischtes Hack wissen?",
    "Wann hat Felix über seine Tochter gesprochen?",
    "Was sind die beliebtesten Running Gags?",
    "Welche Gäste waren in der Sendung?",
  ];
  let placeholderIdx = 0;
  let typewriterTimer: ReturnType<typeof setTimeout>;
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  function typewrite(text: string, onDone: () => void) {
    if (!placeholderEl) return;
    let i = 0;
    placeholderEl.textContent = "";
    function tick() {
      if (!placeholderEl) return;
      if (document.activeElement === heroInput || (heroInput && heroInput.value)) return;
      if (i <= text.length) {
        placeholderEl.textContent = text.slice(0, i) + (i < text.length ? "|" : "");
        i++;
        typewriterTimer = setTimeout(tick, 40 + Math.random() * 30);
      } else {
        placeholderEl.textContent = text;
        onDone();
      }
    }
    tick();
  }

  function eraseAndType() {
    if (!placeholderEl) return;
    if (document.activeElement === heroInput || (heroInput && heroInput.value)) {
      typewriterTimer = setTimeout(eraseAndType, 2000);
      return;
    }
    const currentText = placeholders[placeholderIdx];
    let i = currentText.length;
    function erase() {
      if (!placeholderEl) return;
      if (i > 0) {
        i--;
        placeholderEl.textContent = currentText.slice(0, i) + "|";
        typewriterTimer = setTimeout(erase, 25);
      } else {
        placeholderIdx = (placeholderIdx + 1) % placeholders.length;
        typewriterTimer = setTimeout(() => typewrite(placeholders[placeholderIdx], () => {
          typewriterTimer = setTimeout(eraseAndType, 3000);
        }), 300);
      }
    }
    erase();
  }

  if (!reducedMotion) {
    // Start first typewrite after hero entrance
    setTimeout(() => typewrite(placeholders[0], () => {
      typewriterTimer = setTimeout(eraseAndType, 3000);
    }), 1500);
  } else {
    // Reduced motion: just set text, cycle with simple crossfade
    if (placeholderEl) placeholderEl.textContent = placeholders[0];
    setInterval(() => {
      if (!placeholderEl || document.activeElement === heroInput) return;
      if (heroInput && heroInput.value) return;
      placeholderEl.classList.add("fading");
      setTimeout(() => {
        placeholderIdx = (placeholderIdx + 1) % placeholders.length;
        if (placeholderEl) placeholderEl.textContent = placeholders[placeholderIdx];
        placeholderEl?.classList.remove("fading");
      }, 400);
    }, 4000);
  }
</script>

<!-- Hero parallax -->
<script>
  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    const heroBg = document.getElementById("hero-bg");
    const heroSection = document.getElementById("hero");
    if (heroBg && heroSection) {
      let ticking = false;
      window.addEventListener("scroll", () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          const rect = heroSection.getBoundingClientRect();
          if (rect.bottom > 0) {
            heroBg.style.transform = `translateY(${window.scrollY * 0.3}px)`;
          }
          ticking = false;
        });
      }, { passive: true });
    }
  }
</script>

<!-- Animated number counters -->
<script>
  const counters = document.querySelectorAll<HTMLElement>(".counter");
  counters.forEach((el) => {
    const target = parseInt(el.dataset.target ?? "0", 10);
    if (!target) return;
    const duration = 1800;
    const start = performance.now();
    function tick(now: number) {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3); // ease-out cubic
      el.textContent = Math.round(eased * target).toLocaleString("de-DE");
      if (progress < 1) requestAnimationFrame(tick);
    }
    // Start counting after hero entrance delay
    setTimeout(() => requestAnimationFrame(tick), 900);
  });
</script>

<!-- Topic tag filtering -->
<script>
  const topicFilterBar = document.getElementById("topic-filter-bar");
  const topicFilterLabel = document.getElementById("topic-filter-label");
  const topicFilterClear = document.getElementById("topic-filter-clear");
  let activeTopicFilter = "";

  function setTopicFilter(topic: string) {
    activeTopicFilter = topic;
    if (topicFilterBar && topicFilterLabel) {
      topicFilterBar.classList.remove("hidden");
      topicFilterLabel.textContent = topic;
    }
    // Show all episode cards, then hide non-matching
    document.querySelectorAll<HTMLElement>(".episode-card").forEach((card) => {
      try {
        const topics: string[] = JSON.parse(card.dataset.topics ?? "[]");
        const matches = topics.some((t) => t.toLowerCase() === topic.toLowerCase());
        card.style.display = matches ? "" : "none";
      } catch {
        card.style.display = "none";
      }
    });
    // Expand the "more" grid if hidden
    const moreGrid = document.getElementById("episode-grid-more");
    if (moreGrid?.classList.contains("hidden")) {
      moreGrid.classList.remove("hidden");
    }
  }

  function clearTopicFilter() {
    activeTopicFilter = "";
    topicFilterBar?.classList.add("hidden");
    document.querySelectorAll<HTMLElement>(".episode-card").forEach((card) => {
      card.style.display = "";
    });
  }

  // Delegate click on topic tags
  document.addEventListener("click", (e) => {
    const tag = (e.target as HTMLElement).closest<HTMLElement>(".topic-tag");
    if (!tag) return;
    e.stopPropagation(); // Prevent episode card click
    const topic = tag.dataset.topic;
    if (topic) {
      if (topic === activeTopicFilter) {
        clearTopicFilter();
      } else {
        setTopicFilter(topic);
      }
    }
  });

  topicFilterClear?.addEventListener("click", clearTopicFilter);
</script>

